# Database (Neon PostgreSQL or local Docker)
# Neon 生产请使用 Pooled 连接串（主机名含 -pooler），并加 sslmode=require
# DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/child_ai_tools?schema=public"

# Auth.js — use AUTH_TRUST_HOST in dev so login works on any host/port.
# Set AUTH_URL only in production (e.g. https://your-domain.com).
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"
# AUTH_URL="http://localhost:3000"

# AI (OpenAI-compatible API)
# Zhipu GLM (recommended for China):
# LLM_API_KEY=""
# ZHIPU_API_KEY=""
# LLM_API_URL="https://open.bigmodel.cn/api/paas/v4/chat/completions"
# LLM_MODEL="glm-4-flash-250414"
# DeepSeek:
# LLM_API_KEY=""
# DEEPSEEK_API_KEY=""
# LLM_API_URL="https://api.deepseek.com/v1/chat/completions"
# LLM_MODEL="deepseek-chat"
LLM_API_KEY=""
LLM_API_URL="https://open.bigmodel.cn/api/paas/v4/chat/completions"
LLM_MODEL="glm-4-flash-250414"
DEEPSEEK_API_KEY=""

# Admin bootstrap (first admin email)
ADMIN_EMAIL="admin@example.com"

# App
NEXT_PUBLIC_APP_NAME="小宝打字"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudflare (optional — Workers 需 Paid 计划) — see docs/beta-neon-cloudflare.md
# CLOUDFLARE_ACCOUNT_ID=""
# CLOUDFLARE_API_TOKEN=""

# Vercel (recommended beta deploy) — see docs/beta-neon-vercel.md
# DEPLOY_TARGET=vercel
# VERCEL_TOKEN=""
# VERCEL_ORG_ID=""
# VERCEL_PROJECT_ID=""

# Aliyun HK ECS (no ICP filing) — see docs/beta-aliyun-hk.md
# DEPLOY_TARGET=aliyun
# ALIYUN_SSH_HOST=47.x.x.x
# ALIYUN_SSH_USER=root
# ALIYUN_SSH_KEY_PATH=~/.ssh/aliyun-hk.pem
# ALIYUN_AUTH_URL=http://47.x.x.x

# DEPLOY_TARGET=all  # deploy both Vercel and Aliyun on push
